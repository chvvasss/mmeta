# ============================================
# Meta Ads Command Center — Environment Variables
# ============================================

# ─── Database (ZORUNLU) ───
# Neon.tech: https://neon.tech → yeni proje oluştur → connection string kopyala
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/metaads?sslmode=require

# ─── Redis / Cache (OPSİYONEL) ───
# Upstash: https://upstash.com → yeni Redis DB oluştur → REST credentials kopyala
# Yoksa mock data ile çalışır, cache devre dışı kalır
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# ─── NextAuth (ZORUNLU) ───
# NEXTAUTH_URL: production'da domain adresini yaz (https://mmeta.vercel.app)
# NEXTAUTH_SECRET: `openssl rand -base64 32` ile üret
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_secret_generate_with_openssl

# ─── Facebook OAuth (OPSİYONEL — Meta API bağlantısı için) ───
# Facebook Developer Console'dan al: https://developers.facebook.com
FACEBOOK_CLIENT_ID=your_app_id
FACEBOOK_CLIENT_SECRET=your_app_secret

# ─── Meta API (OPSİYONEL — mock data ile başlayabilirsiniz) ───
META_APP_ID=your_app_id
META_APP_SECRET=your_app_secret
META_ACCESS_TOKEN=your_long_lived_token
META_API_VERSION=v22.0
META_DEFAULT_AD_ACCOUNT=act_XXXXXXXXX

# ─── App Config ───
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_CURRENCY=TRY
NEXT_PUBLIC_DEFAULT_TIMEZONE=Europe/Istanbul
NEXT_PUBLIC_DEFAULT_LOCALE=tr-TR
